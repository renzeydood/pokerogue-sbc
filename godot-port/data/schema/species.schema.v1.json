{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokerogue-sbc.local/schema/species.schema.v1.json",
  "title": "Pokemon Species Schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "species_id",
    "name",
    "types",
    "base_stats"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "species_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$",
      "description": "Stable enum-like ID aligned to Pokerogue SpeciesId naming."
    },
    "pokedex_number": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "types": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/pokemon_type"
      }
    },
    "base_stats": {
      "$ref": "#/$defs/base_stats"
    },
    "catch_rate": {
      "type": "integer",
      "minimum": 1,
      "maximum": 255
    },
    "base_friendship": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "base_exp": {
      "type": "integer",
      "minimum": 1
    },
    "growth_rate": {
      "type": "string",
      "enum": [
        "ERRATIC",
        "FAST",
        "MEDIUM_FAST",
        "MEDIUM_SLOW",
        "SLOW",
        "FLUCTUATING"
      ]
    },
    "source": {
      "$ref": "#/$defs/source"
    }
  },
  "$defs": {
    "pokemon_type": {
      "type": "string",
      "enum": [
        "NORMAL",
        "FIRE",
        "WATER",
        "ELECTRIC",
        "GRASS",
        "ICE",
        "FIGHTING",
        "POISON",
        "GROUND",
        "FLYING",
        "PSYCHIC",
        "BUG",
        "ROCK",
        "GHOST",
        "DRAGON",
        "DARK",
        "STEEL",
        "FAIRY",
        "UNKNOWN"
      ]
    },
    "base_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hp",
        "atk",
        "def",
        "sp_atk",
        "sp_def",
        "spd"
      ],
      "properties": {
        "hp": { "type": "integer", "minimum": 1, "maximum": 255 },
        "atk": { "type": "integer", "minimum": 1, "maximum": 255 },
        "def": { "type": "integer", "minimum": 1, "maximum": 255 },
        "sp_atk": { "type": "integer", "minimum": 1, "maximum": 255 },
        "sp_def": { "type": "integer", "minimum": 1, "maximum": 255 },
        "spd": { "type": "integer", "minimum": 1, "maximum": 255 }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "species_enum_name"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "const": "dependency/pokerogue"
        },
        "species_enum_name": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "generation": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9
        },
        "form_key": {
          "type": "string",
          "default": "DEFAULT"
        }
      }
    }
  }
}
